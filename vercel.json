{
  "version": 2,
  "builds": [
    { "src": "backend/app.py", "use": "@vercel/python" },
    { "src": "frontend/templates/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/app.py" },
    {
      "src": "/(.*)",
      "dest": "frontend/templates/$1",
      "check": true
    }
  ]
}
